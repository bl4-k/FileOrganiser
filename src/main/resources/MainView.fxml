<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<TabPane xmlns="http://javafx.com/javafx/8.0.171"
         xmlns:fx="http://javafx.com/fxml/1"
         fx:controller="com.automation.UIController"
         tabClosingPolicy="UNAVAILABLE">

    <tabs>

        <!-- ================= DASHBOARD ================= -->
        <Tab text="Dashboard">
            <content>
                <VBox alignment="CENTER" spacing="20.0">
                    <padding>
                        <Insets top="20" right="20" bottom="20" left="20"/>
                    </padding>

                    <children>
                        <Label text="File Organiser"
                               style="-fx-font-size: 20px; -fx-font-weight: bold;"/>

                        <HBox alignment="CENTER" spacing="10" >
                            <Button text="Select Folder" onAction="#handleSelectFolder"/>
                            <Label fx:id="pathLabel" text="No folder selected"/>
                        </HBox>

                        <Button fx:id="startBtn"
                                text="Run"
                                onAction="#handleRun"
                                prefWidth="150"
                                prefHeight="40"/>

                        <Label fx:id="statusLabelDashboard" text="Status: Ready"/>
                    </children>
                </VBox>
            </content>
        </Tab>

        <!-- ================= RULES ================= -->
        <Tab text="Rules">
            <content>
                <VBox alignment="CENTER" spacing="20.0">
                    <padding>
                        <Insets top="20" right="20" bottom="20" left="20"/>
                    </padding>

                    <children>
                        <Label text="Configure Extension Rules"
                               style="-fx-font-size: 20px; -fx-font-weight: bold;"/>

                        <TableView fx:id="rulesTable" prefHeight="200" editable="true">
                            <columnResizePolicy>
                                <TableView fx:constant="CONSTRAINED_RESIZE_POLICY"/>
                            </columnResizePolicy>

                            <columns>
                                <TableColumn fx:id="extColumn" text="Extension" prefWidth="25"/>
                                <TableColumn fx:id="folderColumn" text="Target Folder" prefWidth="75"/>
                            </columns>
                        </TableView>

                        <VBox spacing="10">

                            <Label text="Modify Rules" style="-fx-font-weight: bold;"/>

                            <HBox alignment="CENTER_LEFT" spacing="10">
                                <ComboBox fx:id="extComboBox"
                                          promptText="Select or type Ext..."
                                          editable="true"
                                          prefWidth="135"/>

                                <TextField fx:id="newFolderField"
                                           promptText="Select or type folder..."
                                           HBox.hgrow="ALWAYS"/>

                                <Button text="📁" onAction="#handleBrowseNewRuleFolder"/>
                                <Button text="Add Rule" onAction="#handleAddRule"/>
                                <Button text="Remove Selected" onAction="#handleRemoveRule"/>
                            </HBox>

                            <HBox alignment="CENTER_LEFT">
                                <CheckBox fx:id="othersCheckBox"
                                          text="Move unknown file types to 'Others' folder"
                                          selected="true"/>

                                <Region HBox.hgrow="ALWAYS"/>

                                <Button text="Reset to Defaults" onAction="#handleReset"/>
                            </HBox>

                            <Label fx:id="statusLabelRules" text=""/>
                        </VBox>

                    </children>
                </VBox>
            </content>
        </Tab>

        <!-- ================= LOGS ================= -->
        <Tab text="Logs">
            <content>
                <VBox alignment="CENTER" spacing="20.0">
                    <padding>
                        <Insets top="20" right="20" bottom="20" left="20"/>
                    </padding>

                    <children>
                        <Label text="Activity Log"
                               style="-fx-font-size: 20px; -fx-font-weight: bold;"/>

                        <ListView fx:id="logListView" VBox.vgrow="ALWAYS"/>

                        <HBox spacing="10" alignment="CENTER">
                            <Button text="Clear Logs" onAction="#handleClearLogs"/>
                            <Button text="Clear Logs on Disk" onAction="#handleClearStoredLogs"/>
                        </HBox>
                    </children>
                </VBox>
            </content>
        </Tab>

    </tabs>
</TabPane>