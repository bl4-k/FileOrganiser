<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<TabPane xmlns="http://javafx.com/javafx/8.0.171"
         xmlns:fx="http://javafx.com/fxml/1"
         fx:controller="com.automation.UIController"
         tabClosingPolicy="UNAVAILABLE">

    <tabs>

        <!-- ================= DASHBOARD ================= -->
        <Tab text="Dashboard">
            <content>
                <VBox alignment="CENTER" spacing="20.0" styleClass="screen-container">
                    <padding>
                        <Insets top="20" right="20" bottom="20" left="20"/>
                    </padding>

                    <children>
                        <Label text="File Organiser" styleClass="screen-title"/>

                        <HBox alignment="CENTER" spacing="10" >
                            <Button text="_Select Folder" mnemonicParsing="true" onAction="#handleSelectFolder" styleClass="secondary-button"/>
                            <Label fx:id="pathLabel" text="No folder selected"/>
                        </HBox>

                        <Button fx:id="startBtn"
                                text="_Run"
                                mnemonicParsing="true"
                                onAction="#handleRun"
                                prefWidth="150"
                                prefHeight="40"
                                styleClass="primary-button"/>

                        <ProgressIndicator fx:id="runProgressIndicator"
                                           prefHeight="28"
                                           prefWidth="28"
                                           visible="false"
                                           managed="false"/>

                        <Label fx:id="statusLabelDashboard" text="Status: Ready" styleClass="status-ready"/>
                    </children>
                </VBox>
            </content>
        </Tab>

        <!-- ================= RULES ================= -->
        <Tab text="Rules">
            <content>
                <VBox alignment="CENTER" spacing="20.0" styleClass="screen-container">
                    <padding>
                        <Insets top="20" right="20" bottom="20" left="20"/>
                    </padding>

                    <children>
                        <Label text="Configure Extension Rules" styleClass="screen-title"/>

                        <TableView fx:id="rulesTable" prefHeight="200" editable="true">
                            <columnResizePolicy>
                                <TableView fx:constant="CONSTRAINED_RESIZE_POLICY"/>
                            </columnResizePolicy>

                            <columns>
                                <TableColumn fx:id="extColumn" text="Extension" prefWidth="25"/>
                                <TableColumn fx:id="folderColumn" text="Target Folder" prefWidth="75"/>
                            </columns>
                        </TableView>

                        <VBox spacing="10">

                            <Label text="Modify Rules" styleClass="section-title"/>

                            <HBox alignment="CENTER_LEFT" spacing="10">
                                <Label text="Extension"/>
                                <ComboBox fx:id="extComboBox"
                                          promptText="Select or type Ext..."
                                          editable="true"
                                          prefWidth="135"/>

                                <Label text="Target Folder"/>
                                <TextField fx:id="newFolderField"
                                           promptText="Select or type folder..."
                                           HBox.hgrow="ALWAYS"/>

                                <Button fx:id="browseRuleFolderBtn" text="Browse..." onAction="#handleBrowseNewRuleFolder" styleClass="secondary-button">
                                    <tooltip>
                                        <Tooltip text="Choose folder for the selected extension rule"/>
                                    </tooltip>
                                </Button>
                                <Button fx:id="addRuleBtn" text="_Add Rule" mnemonicParsing="true" onAction="#handleAddRule" styleClass="primary-button"/>
                                <Button fx:id="removeRuleBtn" text="Remove Selected" onAction="#handleRemoveRule" styleClass="danger-button"/>
                            </HBox>

                            <HBox alignment="CENTER_LEFT">
                                <CheckBox fx:id="othersCheckBox"
                                          text="Move unknown file types to 'Others' folder"
                                          selected="true"/>

                                <Region HBox.hgrow="ALWAYS"/>

                                <Button fx:id="resetRulesBtn" text="Reset to Defaults" onAction="#handleReset" styleClass="secondary-button"/>
                            </HBox>

                            <Label fx:id="statusLabelRules" text="Status: Ready" styleClass="status-ready"/>
                        </VBox>

                    </children>
                </VBox>
            </content>
        </Tab>

        <!-- ================= LOGS ================= -->
        <Tab text="Logs">
            <content>
                <VBox alignment="CENTER" spacing="20.0" styleClass="screen-container">
                    <padding>
                        <Insets top="20" right="20" bottom="20" left="20"/>
                    </padding>

                    <children>
                        <Label text="Activity Log" styleClass="screen-title"/>

                        <ListView fx:id="logListView" VBox.vgrow="ALWAYS"/>

                        <HBox spacing="10" alignment="CENTER">
                            <Button text="Clear Visible Logs" onAction="#handleClearLogs" styleClass="secondary-button"/>
                            <Button text="Delete Saved Logs" onAction="#handleClearStoredLogs" styleClass="danger-button"/>
                        </HBox>
                    </children>
                </VBox>
            </content>
        </Tab>

    </tabs>
</TabPane>