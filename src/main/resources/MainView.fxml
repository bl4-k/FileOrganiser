<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.geometry.Insets?>

<TabPane xmlns="http://javafx.com/javafx/8.0.171" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.automation.UIController" tabClosingPolicy="UNAVAILABLE">
    <tabs>
        <Tab text="Dashboard">
            <content>
                <VBox alignment="CENTER" spacing="20.0">
                    <children>
                        <Label text="File Organiser" style="-fx-font-size: 20px; -fx-font-weight: bold;"/>
                        <HBox spacing="10" alignment="CENTER">
                            <Button text="Select Folder" onAction="#handleSelectFolder"/>
                            <Label fx:id="pathLabel" text="No folder selected" />
                        </HBox>
                        <Button fx:id="startBtn" text="Run Organiser" onAction="#handleRun" prefWidth="150" prefHeight="40"/>
                        <Label fx:id="statusLabelDashboard" text="Status: Ready" />

                        
                    </children>
                    <padding>
                        <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
                    </padding>
                </VBox>
            </content>
        </Tab>

        <Tab text="Rules">
            <content>
                <VBox alignment="CENTER" spacing="20.0">
                    <children>
                        <Label text="Configure Extension Rules" style="-fx-font-size: 20px; -fx-font-weight: bold;"/>
                        <TableView fx:id="rulesTable" prefHeight="200" editable="true">
                            <columnResizePolicy>
                                <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                            </columnResizePolicy>

                            <columns>
                                <TableColumn fx:id="extColumn" text="Extension" prefWidth="25"/>
                                <TableColumn fx:id="folderColumn" text="Target Folder" prefWidth="75"/>
                            </columns>
                        </TableView>
                        <HBox alignment="CENTER" spacing="10">
                            <VBox spacing="10">
                                <Label text="Add New Rule" style="-fx-font-weight: bold;"/>
                                <HBox alignment="CENTER_LEFT" spacing="10" >
                                    <ComboBox fx:id="extComboBox" promptText="Select or Type Ext" editable="true" maxWidth="-Infinity" prefWidth="135"/>
                                    <TextField fx:id="newFolderField" promptText="Select folder..." editable="true" HBox.hgrow="ALWAYS"/>
                                    <Button text="📁" onAction="#handleBrowseNewRuleFolder"/>
                                    <Button text="Add Rule" onAction="#handleAddRule"/>
                                    <Button text="Remove Selected" onAction="#handleRemoveRule"/>
                                </HBox>
                                <HBox>
                                    <HBox alignment="CENTER_LEFT">
                                    <CheckBox fx:id="othersCheckBox" text="Move unknown file types to 'Others' folder" selected="true"/>
                                    </HBox>
                                    <Region HBox.hgrow="ALWAYS" />
                                    <HBox alignment="CENTER_RIGHT">
                                    <Button text="Reset to Defaults" onAction="#handleReset"/>
                                    </HBox>
                                </HBox>
                                <Label fx:id="statusLabelRules" text=""/>
                            </VBox>
                        </HBox>
                    </children>
                    <padding>
                        <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
                    </padding>
                </VBox>
            </content>
        </Tab>

        <Tab text="Logs">
            <content>
                <VBox alignment="CENTER" spacing="20.0">
                    <children>
                        <Label text="Activity Log" style="-fx-font-size: 20px; -fx-font-weight: bold;"/>

                        <ListView fx:id="logListView" VBox.vgrow="ALWAYS"/>
                        <HBox alignment= "CENTER" spacing="10">
                            <Button text="Clear Logs" onAction="#handleClearLogs"/>
                            <Button text="Clear Stored Logs" onAction="#handleClearStoredLogs"/>
                        </HBox>
                    </children>
                    <padding>
                        <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
                    </padding>
                </VBox>
            </content>
        </Tab>
    </tabs>
</TabPane>
